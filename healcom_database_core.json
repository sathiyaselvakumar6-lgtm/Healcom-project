  "educationalresource": [
    {
      "id": 1,
      "title": "The Orthopedic Recovery Blueprint",
      "description": "A comprehensive guide to bone and joint healing, including nutrition and safe mobility exercises.",
      "content": "\n            <h2>Welcome to your Recovery Blueprint</h2>\n            <p>Recovering from orthopedic surgery requires a balanced approach. This guide covers the three pillars of success:</p>\n            <ul>\n                <li><strong>Nutrition:</strong> High protein and calcium intake are critical for bone density and tissue repair.</li>\n                <li><strong>Mobility:</strong> Controlled, low-impact movements prevent stiffness (ankylosis) and blood clots.</li>\n                <li><strong>Pain Management:</strong> Understanding the difference between \"good pain\" (rehab) and \"bad pain\" (injury).</li>\n            </ul>\n            <h2>Day 1-7 Protocol</h2>\n            <p>Focus on RICE (Rest, Ice, Compression, Elevation). Do not overexert. Your primary goal is inflammation reduction.</p>\n        ",
      "price": "499.00",
      "thumbnail": "",
      "is_active": true,
      "created_at": "2026-03-25T02:14:06.910Z"
    },
    {
      "id": 2,
      "title": "Cardiac Wellness & Strength",
      "description": "Understanding heart-healthy habits and stress management after surgery.",
      "content": "\n            <h2>Your Heart, Re-imagined</h2>\n            <p>Post-cardiac surgery is a new chapter. Let's make it your healthiest one yet.</p>\n            <h3>Daily Habits</h3>\n            <p>Monitoring your blood pressure and heart rate twice daily (morning and evening) is mandatory. Record these in your logs.</p>\n            <h3>Dietary Adjustments</h3>\n            <p>The DASH diet is highly recommended. Reduce sodium to under 1,500mg per day to prevent fluid retention.</p>\n        ",
      "price": "799.00",
      "thumbnail": "",
      "is_active": true,
      "created_at": "2026-03-25T02:14:06.913Z"
    },
    {
      "id": 3,
      "title": "Mindful Healing: Mental Health Guide",
      "description": "Techniques to manage anxiety and stay motivated during long recovery periods.",
      "content": "\n            <h2>Healing is 50% Mental</h2>\n            <p>It is normal to feel frustrated or depressed during slow recovery. This module teaches you cognitive reframing.</p>\n            <h3>Meditation for Pain</h3>\n            <p>Research shows that 10 minutes of daily mindfulness can reduce perceived pain levels by up to 30%.</p>\n        ",
      "price": "299.00",
      "thumbnail": "",
      "is_active": true,
      "created_at": "2026-03-25T02:14:06.915Z"
    },
